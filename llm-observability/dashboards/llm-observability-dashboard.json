{
  "id": null,
  "uid": "llm-observability-v1",
  "title": "LLM Observability",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "prompt_version",
        "type": "query",
        "label": "Prompt Version",
        "datasource": {"type": "postgres", "uid": "PostgreSQL"},
        "query": "SELECT DISTINCT COALESCE(NULLIF(TRIM(prompt_version), ''), 'unversioned') AS value FROM llm_requests ORDER BY value",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Latency p50",
      "gridPos": {"x": 0, "y": 0, "w": 8, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(request_latency_seconds_bucket{prompt_version=~\"${prompt_version:regex}\"}[5m])) by (le))",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency p95",
      "gridPos": {"x": 8, "y": 0, "w": 8, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(request_latency_seconds_bucket{prompt_version=~\"${prompt_version:regex}\"}[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency p99",
      "gridPos": {"x": 16, "y": 0, "w": 8, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(request_latency_seconds_bucket{prompt_version=~\"${prompt_version:regex}\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tokens per Minute",
      "gridPos": {"x": 8, "y": 8, "w": 8, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(increase(token_usage_total{prompt_version=~\"${prompt_version:regex}\"}[1m]))",
          "legendFormat": "tokens/min"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Cost per Day (USD)",
      "gridPos": {"x": 16, "y": 8, "w": 8, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(daily_cost_usd{prompt_version=~\"${prompt_version:regex}\"})",
          "legendFormat": "daily cost"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Quality Score Trends",
      "gridPos": {"x": 0, "y": 16, "w": 24, "h": 8},
      "datasource": {"type": "postgres", "uid": "PostgreSQL"},
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT q.created_at AS time, AVG(q.score) AS value FROM quality_scores q JOIN llm_requests r ON r.id = q.request_id WHERE COALESCE(NULLIF(TRIM(r.prompt_version), ''), 'unversioned') ~ '${prompt_version:regex}' GROUP BY q.created_at ORDER BY q.created_at",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Model Drift (Avg Tokens per Request)",
      "gridPos": {"x": 0, "y": 24, "w": 24, "h": 8},
      "datasource": {"type": "postgres", "uid": "PostgreSQL"},
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT detected_at AS time, CONCAT(model, ' / ', COALESCE(NULLIF(TRIM(prompt_version), ''), 'unversioned')) AS metric, delta_pct AS value FROM drift_metrics WHERE metric_name = 'total_tokens' AND COALESCE(NULLIF(TRIM(prompt_version), ''), 'unversioned') ~ '${prompt_version:regex}' ORDER BY detected_at",
          "refId": "A"
        }
      ]
    }
  ]
}
